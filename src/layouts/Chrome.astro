---
import NavBar from "@components/NavBar.astro";
import { Font } from "astro:assets";

interface Props {
  title: string;
}

const { title } = Astro.props;

import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.svg" />

    <Font cssVariable="--font-jetbrains-mono" />
    <Font cssVariable="--font-lora" />

    <title>{`PT | ${title}`}</title>
  </head>

  <body class="bg-slate-900">
    <header
      class="bg-slate-800
      w-full h-12 m-0
      shadow-slate-800 shadow-lg
      border-solid border-b-4 border-slate-200"
    >
      <NavBar base="PT.Blog_" links={["/blog"]} />
    </header>
    <main class="w-full h-fit">

      <slot />
    </main>
  </body>
</html>
